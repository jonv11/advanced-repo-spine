# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.sln]
indent_style = tab

[*.{csproj,props,targets}]
indent_size = 2

[Makefile]
indent_style = tab
